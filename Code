// ==================== CONSTANTS ====================
const int MAX_HOTELS = 50;
const int MAX_TRAVELERS = 100;
const int MAX_REVIEWS = 200;

// ==================== REVIEW CLASS ====================
/**
 * Review Class - Encapsulates a single review
 * This class is used in COMPOSITION by Traveler
 * Attributes: reviewID, userID, hotelName, rating, reviewText, date
 */
class Review {
private:
    int reviewID;
    int userID;
    string hotelName;
    double rating;
    string reviewText;
    string date;

public:
    // Constructor
    Review() : reviewID(0), userID(0), hotelName(""), rating(0.0), reviewText(""), date("") {}
    
    Review(int rid, int uid, string hotel, double r, string text, string d)
        : reviewID(rid), userID(uid), hotelName(hotel), rating(r), reviewText(text), date(d) {}

    // Getters
    int getReviewID() const { return reviewID; }
    int getUserID() const { return userID; }
    string getHotelName() const { return hotelName; }
    double getRating() const { return rating; }
    string getReviewText() const { return reviewText; }
    string getDate() const { return date; }

    // OPERATOR OVERLOADING: Compare reviews by rating
    // This operator will be used in Top-Pick Matcher
    bool operator>(const Review& other) const {
        return this->rating > other.rating;
    }

    bool operator<(const Review& other) const {
        return this->rating < other.rating;
    }

    // Display review
    void display() const {
        cout << "  Review ID: " << reviewID << " | User: " << userID 
             << " | Rating: " << fixed << setprecision(1) << rating << "/5.0" << endl;
        cout << "  Text: " << reviewText << " | Date: " << date << endl << endl;
    }
};

// ==================== PERSON CLASS (Base Class) ====================
/**
 * Person Class - Base class for travelers
 * INHERITANCE: This is the parent class
 * Provides: id, name, email
 * INHERITANCE PRINCIPLE: Encapsulates common attributes
 */
class Person {
protected:
    int id;
    string name;
    string email;

public:
    // Constructor
    Person() : id(0), name(""), email("") {}
    
    Person(int pid, string pname, string pemail)
        : id(pid), name(pname), email(pemail) {}

    // Getters
    int getID() const { return id; }
    string getName() const { return name; }
    string getEmail() const { return email; }

    // Setters
    void setName(string n) { name = n; }
    void setEmail(string e) { email = e; }

    // Virtual-like method (will be overridden in child)
    virtual void displayProfile() const {
        cout << "ID: " << id << " | Name: " << name << " | Email: " << email << endl;
    }

    virtual ~Person() {}
};

// ==================== TRAVELER CLASS (Derived Class) ====================
/**
 * Traveler Class - Inherits from Person
 * INHERITANCE: Adds new attributes specific to travelers
 *   - membershipLevel (NEW)
 *   - loyaltyPoints (NEW)
 * COMPOSITION: "Owns" an array of Review objects (HAS-A relationship)
 * This is the PRIMARY ENTITY used in main()
 */
class Traveler : public Person {
private:
    string membershipLevel;  // Gold, Silver, Bronze (NEW data)
    int loyaltyPoints;       // Loyalty points (NEW data)
    Review authoredReviews[MAX_REVIEWS];  // COMPOSITION: Array of Review objects
    int reviewCount;

public:
    // Constructor
    Traveler() : Person(), membershipLevel("Bronze"), loyaltyPoints(0), reviewCount(0) {}
    
    Traveler(int pid, string pname, string pemail, string mlevel, int lpoints)
        : Person(pid, pname, pemail), membershipLevel(mlevel), loyaltyPoints(lpoints), reviewCount(0) {}

    // NEW GETTERS for child-specific attributes
    string getMembershipLevel() const { return membershipLevel; }
    int getLoyaltyPoints() const { return loyaltyPoints; }
    int getReviewCount() const { return reviewCount; }

    // NEW SETTERS for child-specific attributes
    void setMembershipLevel(string level) { membershipLevel = level; }
    void setLoyaltyPoints(int points) { loyaltyPoints = points; }

    // COMPOSITION METHOD: Add review to traveler
    bool addReview(const Review& review) {
        if (reviewCount >= MAX_REVIEWS) {
            return false;
        }
        authoredReviews[reviewCount++] = review;
        
        // Award loyalty points for writing review
        int pointsAwarded = (int)review.getRating() * 10;  // 1 star = 10 points
        loyaltyPoints += pointsAwarded;
        updateMembershipLevel();  // Auto-update membership based on points
        
        return true;
    }

    // Retrieve specific review by index
    Review getReview(int index) const {
        if (index >= 0 && index < reviewCount) {
            return authoredReviews[index];
        }
        return Review();
    }

    // COMPOSITION METHOD: Get all reviews
    Review* getAllReviews() {
        return authoredReviews;
    }

    // Automatically upgrade/downgrade membership level based on loyalty points
    void updateMembershipLevel() {
        if (loyaltyPoints >= 500) {
            membershipLevel = "Platinum";
        } else if (loyaltyPoints >= 300) {
            membershipLevel = "Gold";
        } else if (loyaltyPoints >= 100) {
            membershipLevel = "Silver";
        } else {
            membershipLevel = "Bronze";
        }
    }

    // OVERRIDDEN METHOD: Display with traveler-specific info
    // This shows inheritance behavior - child extends parent display
    void displayProfile() const override {
        cout << "========== TRAVELER PROFILE ==========" << endl;
        Person::displayProfile();
        cout << "Membership Level: " << membershipLevel << endl;
        cout << "Loyalty Points: " << loyaltyPoints << endl;
        cout << "Reviews Written: " << reviewCount << endl;
        cout << "=====================================" << endl;
    }

    // Display all authored reviews (COMPOSITION in action)
    void displayAuthoredReviews() const {
        if (reviewCount == 0) {
            cout << "This traveler has not written any reviews." << endl;
            return;
        }
        cout << "\nAuthor: " << name << " - Reviews (" << reviewCount << "):" << endl;
        for (int i = 0; i < reviewCount; i++) {
            cout << "[" << (i+1) << "] ";
            authoredReviews[i].display();
        }
    }

    // OPERATOR OVERLOADING: Compare travelers by loyalty points
    bool operator>(const Traveler& other) const {
        return this->loyaltyPoints > other.loyaltyPoints;
    }
};

// ==================== HOTEL CLASS ====================
/**
 * Hotel Class - Manages hotel data and reviews
 * This is a PRIMARY entity that can be queried
 * Attributes: hotelID, hotelName, location, reviews
 */
class Hotel {
private:
    int hotelID;
    string hotelName;
    string location;
    Review hotelReviews[MAX_REVIEWS];
    int reviewCount;
    double totalRating;  // For efficient average calculation

public:
    // Constructor
    Hotel() : hotelID(0), hotelName(""), location(""), reviewCount(0), totalRating(0.0) {}
    
    Hotel(int hid, string hname, string hloc)
        : hotelID(hid), hotelName(hname), location(hloc), reviewCount(0), totalRating(0.0) {}

    // Getters
    int getHotelID() const { return hotelID; }
    string getHotelName() const { return hotelName; }
    string getLocation() const { return location; }
    int getReviewCount() const { return reviewCount; }
    double getAverageRating() const {
        if (reviewCount == 0) return 0.0;
        return totalRating / reviewCount;
    }

    // Add review to hotel's collection
    bool addReview(const Review& review) {
        if (reviewCount >= MAX_REVIEWS) {
            return false;
        }
        hotelReviews[reviewCount++] = review;
        totalRating += review.getRating();
        return true;
    }

    // Get review by index
    Review getReview(int index) const {
        if (index >= 0 && index < reviewCount) {
            return hotelReviews[index];
        }
        return Review();
    }

    // Get all reviews
    Review* getAllReviews() {
        return hotelReviews;
    }

    // Display hotel information and all reviews
    void displayFullProfile() const {
        cout << "\n========== HOTEL: " << hotelName << " ==========" << endl;
        cout << "ID: " << hotelID << " | Location: " << location << endl;
        cout << "Total Reviews: " << reviewCount << endl;
        cout << "Average Rating: " << fixed << setprecision(2) << getAverageRating() << "/5.0" << endl;
        cout << "======================================\n" << endl;

        if (reviewCount == 0) {
            cout << "No reviews available for this hotel." << endl;
            return;
        }

        cout << "REVIEWS:" << endl;
        for (int i = 0; i < reviewCount; i++) {
            cout << "[" << (i+1) << "] ";
            hotelReviews[i].display();
        }
    }

    // OPERATOR OVERLOADING: Compare hotels by average rating
    // This is used in Top-Pick Matcher feature
    bool operator>(const Hotel& other) const {
        return this->getAverageRating() > other.getAverageRating();
    }

    bool operator<(const Hotel& other) const {
        return this->getAverageRating() < other.getAverageRating();
    }

    // For output stream compatibility
    friend ostream& operator<<(ostream& out, const Hotel& h);
};

// ==================== FRIEND FUNCTION ====================
/**
 * FRIEND FUNCTION: generateHotelRankingReport
 * Purpose: Access private hotel data to generate analytics
 * This function needs access to PRIVATE members:
 *   - hotelName (to display in report)
 *   - reviewCount (to show volume)
 *   - totalRating (to calculate average)
 * 
 * Why friend function (not member)?
 * - It's a utility/analytics function
 * - It accesses multiple private members
 * - It's external utility, not core hotel behavior
 * - Cleaner than making members public
 */
ostream& operator<<(ostream& out, const Hotel& h) {
    out << "Hotel: " << h.hotelName << " (ID: " << h.hotelID << ")"
        << " | Avg Rating: " << fixed << setprecision(2) << h.getAverageRating()
        << "/5.0 | Reviews: " << h.reviewCount;
    return out;
}

/**
 * FRIEND FUNCTION for generating detailed analytics
 * Accesses private: hotelName, reviewCount, totalRating
 * Could NOT be a member function (external utility)
 */
void generateHotelAnalyticsReport(const Hotel& hotel) {
    cout << "\n========== ANALYTICS REPORT ==========" << endl;
    cout << "Hotel: " << hotel.hotelName << endl;
    cout << "Total Reviews in System: " << hotel.reviewCount << endl;
    
    if (hotel.reviewCount == 0) {
        cout << "Rating: No data available" << endl;
    } else {
        cout << "Cumulative Rating: " << fixed << setprecision(1) << hotel.totalRating << endl;
        cout << "Average Rating: " << fixed << setprecision(2) << hotel.getAverageRating() << "/5.0" << endl;
        cout << "Rating Stability: " << (hotel.reviewCount >= 10 ? "Reliable" : "Limited data") << endl;
    }
    cout << "=====================================\n" << endl;
}

// ==================== UTILITY FUNCTIONS FOR FILE I/O ====================

/**
 * CRITICAL CONSTRAINT: Read files EXACTLY ONCE at startup
 * Parse data WITHOUT processing logic
 * All processing happens in class methods
 */

// Load travelers from Users.txt
void loadTravelersFromFile(Traveler travelers[], int& travelerCount) {
    ifstream file("Users.txt");
    
    if (!file.is_open()) {
        cout << "Warning: Users.txt not found. Creating empty traveler array." << endl;
        travelerCount = 0;
        return;
    }

    string line;
    travelerCount = 0;
    
    while (getline(file, line) && travelerCount < MAX_TRAVELERS) {
        // Parse ONLY - no processing logic here
        stringstream ss(line);
        int id, points;
        string name, email, level;
        char delimiter;

        if (ss >> id >> delimiter >> ws) {
            getline(ss, name, '|');
            getline(ss, email, '|');
            getline(ss, level, '|');
            ss >> points;

            // Create traveler object
            Traveler t(id, name, email, level, points);
            travelers[travelerCount++] = t;
        }
    }

    file.close();
    cout << "Loaded " << travelerCount << " travelers." << endl;
}

// Load reviews from Reviews.txt
void loadReviewsIntoEntities(Traveler travelers[], int travelerCount, 
                             Hotel hotels[], int& hotelCount) {
    ifstream file("Reviews.txt");
    
    if (!file.is_open()) {
        cout << "Warning: Reviews.txt not found." << endl;
        return;
    }

    string line;
    hotelCount = 0;
    
    while (getline(file, line)) {
        // Parse ONLY - no processing logic here
        stringstream ss(line);
        int reviewID, userID;
        string hotelName, ratingStr, reviewText, date;
        double rating;
        char delimiter;

        if (ss >> reviewID >> delimiter >> ws) {
            ss >> userID >> delimiter >> ws;
            getline(ss, hotelName, '|');
            getline(ss, ratingStr, '|');
            rating = stod(ratingStr);
            getline(ss, reviewText, '|');
            getline(ss, date);

            // Create review object
            Review rev(reviewID, userID, hotelName, rating, reviewText, date);

            // Add to corresponding traveler (COMPOSITION in action)
            for (int i = 0; i < travelerCount; i++) {
                if (travelers[i].getID() == userID) {
                    travelers[i].addReview(rev);
                    break;
                }
            }

            // Add to hotel or create new hotel if not exists
            int hotelIndex = -1;
            for (int i = 0; i < hotelCount; i++) {
                if (hotels[i].getHotelName() == hotelName) {
                    hotelIndex = i;
                    break;
                }
            }

            if (hotelIndex == -1) {
                // New hotel
                if (hotelCount < MAX_HOTELS) {
                    hotels[hotelCount] = Hotel(hotelCount + 1, hotelName, "Unknown");
                    hotelIndex = hotelCount++;
                }
            }

            if (hotelIndex != -1) {
                hotels[hotelIndex].addReview(rev);
            }
        }
    }

    file.close();
    cout << "Loaded reviews and created " << hotelCount << " hotels." << endl;
}

