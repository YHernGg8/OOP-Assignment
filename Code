// ==================== SAVE DATA TO OUTPUT FILE ====================
void saveDataToFile(Traveler travelers[], int travelerCount,
                    Hotel hotels[], int hotelCount) {
    ofstream file("output.txt");

    if (!file.is_open()) {
        cout << "Error: Could not create output file." << endl;
        return;
    }

    // Write traveler summary
    file << "========== TRAVELER SUMMARY ==========" << endl;
    file << "Total Travelers: " << travelerCount << endl << endl;
    for (int i = 0; i < travelerCount; i++) {
        file << "ID: " << travelers[i].getID() << " | "
             << "Name: " << travelers[i].getName() << " | "
             << "Level: " << travelers[i].getMembershipLevel() << " | "
             << "Points: " << travelers[i].getLoyaltyPoints() << endl;
    }

    // Write hotel summary
    file << "\n========== HOTEL SUMMARY ==========" << endl;
    file << "Total Hotels: " << hotelCount << endl << endl;
    for (int i = 0; i < hotelCount; i++) {
        file << "Hotel: " << hotels[i].getHotelName() << " | "
             << "Reviews: " << hotels[i].getReviewCount() << " | "
             << "Avg Rating: " << fixed << setprecision(2) 
             << hotels[i].getAverageRating() << "/5.0" << endl;
    }

    file.close();
    cout << "\nData saved to output.txt" << endl;
}

// ==================== MAIN FUNCTION ====================
/**
 * CRITICAL ARCHITECTURE REQUIREMENT:
 * - PRIMARY ENTITY: Traveler array (not a manager class)
 * - ONE-TIME I/O: Load at start, save at end
 * - ALL LOGIC: In class methods, not in main
 */
int main() {
    cout << "========== HOTEL REVIEW SYSTEM ==========" << endl;
    cout << "Loading data..." << endl << endl;

    // PRIMARY ENTITY: Traveler array (Entity-centric design)
    Traveler travelers[MAX_TRAVELERS];
    int travelerCount = 0;

    Hotel hotels[MAX_HOTELS];
    int hotelCount = 0;

    // CRITICAL: ONE-TIME I/O - Read files exactly once at startup
    loadTravelersFromFile(travelers, travelerCount);
    loadReviewsIntoEntities(travelers, travelerCount, hotels, hotelCount);

    // Main loop
    int choice = 0;
    while (choice != 5) {
        displayMenu();
        cin >> choice;

        switch (choice) {
            case 1:
                propertyDeepDive(hotels, hotelCount);
                break;
            case 2:
                travelerProfileManagement(travelers, travelerCount);
                break;
            case 3:
                topPickMatcher(hotels, hotelCount);
                break;
            case 4:
                topReviewers(travelers, travelerCount);
                break;
            case 5:
                cout << "\nExiting system..." << endl;
                break;
            default:
                cout << "Invalid choice. Please try again." << endl;
        }
    }

    // CRITICAL: ONE-TIME I/O - Write to file exactly once at exit
    cout << "Saving data..." << endl;
    saveDataToFile(travelers, travelerCount, hotels, hotelCount);

    cout << "Program terminated." << endl;
    return 0;
}

